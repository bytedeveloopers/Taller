# Environment variables declared in this file are available at build time and runtime.
# Do not commit this file to version control as it contains secrets.

# Database
DATABASE_URL="mysql://username:password@localhost:3306/taller_db"

# NextAuth.js
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# JWT
JWT_SECRET="your-jwt-secret-here"

# Email (opcional para notificaciones)
EMAIL_SERVER="smtp://username:password@smtp.example.com:587"
EMAIL_FROM="noreply@taller.com"
